    {
      "id": "moe-ebias-txt", "type": "text",
      "x": 58, "y": 266, "width": 380, "height": 80,
      "text": "expert_bias — 偏置统计\nexpert_bias_mean = bias.mean()\nexpert_bias_std = bias.std()\n⚠ 均值偏离零→系统性偏向  std大→差异显著",
      "fontSize": 15, "fontFamily": 1, "textAlign": "left",
      "strokeColor": "#343a40", "backgroundColor": "transparent",
