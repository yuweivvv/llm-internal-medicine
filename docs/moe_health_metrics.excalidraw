    {
      "id": "moe-rent-txt", "type": "text",
      "x": 58, "y": 118, "width": 380, "height": 80,
      "text": "router_entropy — 路由分布均匀度\nH = −Σ(p_i · log p_i)\np = softmax 后路由概率分布\n⚠ 低熵 → 路由集中, 专家坍缩风险",
      "fontSize": 15, "fontFamily": 1, "textAlign": "left",
      "strokeColor": "#343a40", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "angle": 0, "seed": 206, "version": 1, "versionNonce": 206,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "groupIds": []
    },

    {
