    },
    {
      "id": "moe-ssum-txt", "type": "text",
      "x": 475, "y": 118, "width": 380, "height": 80,
      "text": "score_sum — TopK 置信度\ntopk_scores.sum(dim=-1)\n输出 mean / min / max 三项统计\n⚠ 过低→不自信  接近 1.0→过集中",
      "fontSize": 15, "fontFamily": 1, "textAlign": "left",
      "strokeColor": "#343a40", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "angle": 0, "seed": 208, "version": 1, "versionNonce": 208,
